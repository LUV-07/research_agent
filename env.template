# ══════════════════════════════════════════════════════════════════════════════
# Research Agent — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.template .env
#   2. Fill in your real API keys below
#   3. NEVER commit .env to version control
#   4. Add .env to your .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─── Groq (LLaMA 3.1) ─────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Tavily Web Search ─────────────────────────────────────────────────────────
# Get your key at: https://app.tavily.com/home
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ─── LangSmith Observability ──────────────────────────────────────────────────
# Get your key at: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_your_langsmith_api_key_here
LANGCHAIN_PROJECT=research-agent

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Default: local Docker container. Change for remote Redis.
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600  # seconds — cached results expire after 1 hour

# ─── Agent Behaviour ──────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant   # or llama-3.1-70b-versatile for higher quality
MAX_CRITIC_ITERATIONS=2            # max loops between Critic → Researcher
TAVILY_MAX_RESULTS=3               # top-N search results per sub-question

# ─── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true   # set to false in production
